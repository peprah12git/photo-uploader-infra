        <!-- GitHub Actions → ECR (push image) -->
        <mxCell id="e21" value="docker push (OIDC)" style="edgeStyle=orthogonalEdgeStyle;fontSize=9;" edge="1" source="gh_actions_app" target="ecr" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ECR → EventBridge -->
