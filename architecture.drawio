        <mxCell id="as_legend" value="Auto Scaling&#xa;&#xa;Min: 1  |  Desired: 1  |  Max: 4&#xa;Metric: CPU utilisation ≥ 70%&#xa;Scale-out cooldown: 60 s&#xa;Scale-in  cooldown: 300 s" style="text;html=1;strokeColor=#00897B;fillColor=#E0F2F1;align=left;verticalAlign=top;spacingLeft=6;spacingTop=6;fontSize=9;rounded=1;fontStyle=1;" vertex="1" parent="1">
