          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ── CI/CD edges ── -->

        <!-- GitHub App → GitHub Actions -->
        <mxCell id="e20" value="code push" style="edgeStyle=orthogonalEdgeStyle;fontSize=9;" edge="1" source="gh_app" target="gh_actions_app" parent="1">
          <mxGeometry relative="1" as="geometry"/>
