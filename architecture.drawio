        <!-- ═══ ANNOTATION BOXES ═══ -->
        <mxCell id="sg_legend" value="Security Groups (Least Privilege)&#xa;&#xa;ALB SG:  in 80,443 from 0.0.0.0/0&#xa;            out 8080 only&#xa;ECS SG:  in 8080 from ALB SG only&#xa;VPCE SG: in 443 from ECS SG only" style="text;html=1;strokeColor=#FF6600;fillColor=#FFF3E0;align=left;verticalAlign=top;spacingLeft=6;spacingTop=6;fontSize=9;rounded=1;fontStyle=1;" vertex="1" parent="1">
