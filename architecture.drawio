        </mxCell>

        <mxCell id="cd" value="CodeDeploy&#xa;&#xa;Blue/Green&#xa;AllAtOnce" style="shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.codedeploy;labelBackgroundColor=#ffffff;sketch=0;fontSize=9;fontStyle=1;" vertex="1" parent="1">
