        </mxCell>

        <!-- VPC Endpoints → ECR (private) -->
        <mxCell id="e8" value="HTTPS (private)" style="edgeStyle=orthogonalEdgeStyle;fontSize=9;dashed=1;strokeColor=#8C4FFF;" edge="1" source="vpce_ecr_api" target="ecr" parent="1">
